# Database
DATABASE_URL=postgresql+psycopg://user:pass@host/dbname?sslmode=require

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7

# Shopify
SHOPIFY_STORE_DOMAIN=yourstore.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_...
SHOPIFY_API_VERSION=2025-01

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# App
APP_ENV=local
APP_SECRET=change-me
WORKER_INTERVAL_SECONDS=600
LOG_LEVEL=INFO

# Safety switches
DRY_RUN=true                  # When true, nothing writes to Google Ads. Recommendations only.
AUTONOMOUS_MODE=false         # When false, all actions require approval regardless of policy.

# ---- Helena: Instagram/Meta + Email marketing agent --------------------
# Swappable execution backends. "browser" drives the Chrome browser agent;
# "api" uses the official APIs (stubbed until we have push access).
META_EXECUTION_MODE=browser   # browser | api
EMAIL_DELIVERY_MODE=browser   # browser | api

# Browser agent (Claude-driven Chrome automation) connection
BROWSER_AGENT_URL=
BROWSER_AGENT_TOKEN=

# Google Flow / Imagen image generation. Pick ONE auth path:
#  (A) Service account (Vertex AI) — set the SA key JSON + project (+ location):
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_FLOW_PROJECT_ID=
GOOGLE_VERTEX_LOCATION=us-central1
#  (B) API key (Generative Language API) — set just the key:
GOOGLE_FLOW_API_KEY=
# Model used by either path:
GOOGLE_FLOW_IMAGE_MODEL=imagen-3.0-generate-002

# S3-compatible object storage (generated images, email assets)
S3_ENDPOINT_URL=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Future MetaApiProvider — leave empty until official access is granted
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
